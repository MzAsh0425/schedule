rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // events コレクション
    match /events/{eventId} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasAll(['title', 'candidates', 'ownerTokenHash'])
                    && request.resource.data.ownerTokenHash is string
                    && request.resource.data.ownerTokenHash.size() == 64
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 500
                    && request.resource.data.candidates is list
                    && request.resource.data.candidates.size() > 0
                    && request.resource.data.candidates.size() <= 100
                    && (!request.resource.data.keys().hasAny(['memo']) || (
                         request.resource.data.memo is string
                         && request.resource.data.memo.size() <= 2000
                       ))
                    && !request.resource.data.keys().hasAny(['ownerToken']);

      // ownerTokenHash: 既存ドキュメントに存在する場合は一致必須（後方互換: ownerToken も許容）
      allow update: if request.resource.data.keys().hasAll(['title', 'candidates'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 500
                    && request.resource.data.candidates is list
                    && request.resource.data.candidates.size() > 0
                    && request.resource.data.candidates.size() <= 100
                    && (!request.resource.data.keys().hasAny(['memo']) || (
                         request.resource.data.memo is string
                         && request.resource.data.memo.size() <= 2000
                       ))
                    && !request.resource.data.keys().hasAny(['ownerToken'])
                    // 新形式: ownerTokenHash で照合
                    && (
                         (!resource.data.keys().hasAny(['ownerTokenHash', 'ownerToken']))
                         || (resource.data.keys().hasAny(['ownerTokenHash'])
                             && request.resource.data.ownerTokenHash is string
                             && request.resource.data.ownerTokenHash == resource.data.ownerTokenHash)
                         // 後方互換: 旧形式 ownerToken が残っている場合
                         || (resource.data.keys().hasAny(['ownerToken'])
                             && !resource.data.keys().hasAny(['ownerTokenHash'])
                             && request.resource.data.ownerTokenHash is string)
                       );

      allow delete: if false;

      // answers サブコレクション
      match /answers/{answerId} {
        allow read: if true;

        allow create: if request.resource.data.keys().hasAll(['name', 'deleteTokenHash'])
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && request.resource.data.name.size() <= 200
                      && request.resource.data.deleteTokenHash is string
                      && request.resource.data.deleteTokenHash.size() == 64
                      && (!request.resource.data.keys().hasAny(['matrix']) || (
                           request.resource.data.matrix is map
                           && request.resource.data.matrix.size() <= 500
                         ))
                      && !request.resource.data.keys().hasAny(['deleteToken']);

        // deleteTokenHash: 既存ドキュメントに存在する場合は一致必須（後方互換: deleteToken も許容）
        allow update: if request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && request.resource.data.name.size() <= 200
                      && (!request.resource.data.keys().hasAny(['matrix']) || (
                           request.resource.data.matrix is map
                           && request.resource.data.matrix.size() <= 500
                         ))
                      && !request.resource.data.keys().hasAny(['deleteToken'])
                      // 新形式: deleteTokenHash で照合
                      && (
                           (!resource.data.keys().hasAny(['deleteTokenHash', 'deleteToken']))
                           || (resource.data.keys().hasAny(['deleteTokenHash'])
                               && request.resource.data.deleteTokenHash is string
                               && request.resource.data.deleteTokenHash == resource.data.deleteTokenHash)
                           // 後方互換: 旧形式 deleteToken が残っている場合
                           || (resource.data.keys().hasAny(['deleteToken'])
                               && !resource.data.keys().hasAny(['deleteTokenHash'])
                               && request.resource.data.deleteTokenHash is string)
                         );

        // 物理削除は禁止（論理削除のみ: isDeleted フラグで管理）
        allow delete: if false;
      }
    }

    // 上記以外のコレクションへのアクセスを拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
